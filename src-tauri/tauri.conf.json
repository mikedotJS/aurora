{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Aurora",
  "version": "0.1.0",
  "identifier": "com.aurora.terminal",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "Aurora",
        "width": 1080,
        "height": 720,
        "minWidth": 720,
        "minHeight": 460,
        "decorations": false,
        "transparent": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "createUpdaterArtifacts": true,
    "category": "DeveloperTool",
    "copyright": "© 2026 Michaël Bernard Romain",
    "shortDescription": "A real, Claude-powered terminal.",
    "longDescription": "Aurora is a native macOS terminal with a Warp-style command-blocks UI, a smart React-owned prompt, GitLab merge-request integration, per-repo scripts, and Claude-powered command suggestions.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "11.0",
      "signingIdentity": "Developer ID Application: Michaël, Bemard ROMAIN (D7F9KXB7PH)",
      "entitlements": "entitlements.plist"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDVBOTQ4NUE5RTQwNkY0MzYKUldRMjlBYmtxWVdVV29tbXovaFZnZTdxKy9yZTM2WnY4VE1lZUppME5PMEQvbm1zU3ZRMzIzbEoK",
      "endpoints": [
        "https://github.com/mikedotjs/aurora/releases/latest/download/latest.json"
      ]
    }
  }
}
